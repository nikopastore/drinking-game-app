# ===========================================
# SipWiki Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# SUPABASE (Required for comments, ratings, submissions)
# -------------------------------------------
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -------------------------------------------
# OPENAI (Required for AI Referee chat)
# -------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# -------------------------------------------
# SETUP INSTRUCTIONS
# -------------------------------------------
#
# 1. SUPABASE SETUP:
#    - Create a new project at https://supabase.com
#    - Go to Settings > API to find your URL and anon key
#    - Run the SQL in /supabase/schema.sql in the SQL Editor
#    - Enable Google OAuth in Authentication > Providers
#
# 2. OPENAI SETUP:
#    - Create an account at https://platform.openai.com
#    - Generate an API key
#    - The app uses gpt-4o-mini for cost efficiency
#
# 3. AMAZON AFFILIATE LINKS:
#    - Edit src/config/monetizationConfig.ts
#    - Replace YOUR_TAG with your Amazon Associate tag
#
# 4. VERCEL DEPLOYMENT:
#    - Push to GitHub
#    - Import project in Vercel
#    - Add these environment variables in Vercel dashboard
